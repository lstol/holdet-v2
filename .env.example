# Copy this file to .env and fill in real values.
# NEVER commit .env to git (it is in .gitignore).

# Login credentials — used by capture_cookie.py for automated cookie capture
HOLDET_EMAIL=lasse.stoltenberg@gmail.com
HOLDET_PASSWORD=<your_password>

# Session cookie — auto-populated by engine/siv/capture_cookie.py
# Full string requires 5 cookies: __Secure-better-auth.session_token,
# __Secure-better-auth.session_data, session, AWSALB, AWSALBCORS
# ⚠ AWSALB is IP-sticky — capture from the same machine you run scripts on.
# Refresh when requests return 401 or 403.
HOLDET_COOKIE=__Secure-better-auth.session_token=<token>; __Secure-better-auth.session_data=<jwt>; session=<uuid>; AWSALB=<token>; AWSALBCORS=<token>

# Game and team identifiers (fixed for Giro 2026)
HOLDET_GAME_ID=612
HOLDET_GAME_ID_GIRO=612
HOLDET_GAME_ID_TDF=TBC
HOLDET_FANTASY_TEAM_ID=6796783
HOLDET_CARTRIDGE=giro-d-italia-2026
HOLDET_CARTRIDGE_TDF=tour-de-france-2026
