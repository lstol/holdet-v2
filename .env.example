# Copy this file to .env and fill in real values.
# NEVER commit .env to git (it is in .gitignore).

# Session cookie from a logged-in holdet.dk browser session.
# How to get it:
#   1. Chrome → holdet.dk → log in
#   2. F12 → Network → Fetch/XHR
#   3. Navigate to rider market
#   4. Find any 'players' request → Headers → copy Cookie header value
#
# ⚠ AWSALB is IP-sticky — capture from the same machine/network you run scripts on.
# ⚠ Refresh when requests return 401 or 403.
HOLDET_COOKIE=session=<uuid>; AWSALB=<token>; AWSALBCORS=<token>

# Game and team identifiers (these are fixed for Giro 2026)
HOLDET_GAME_ID=612
HOLDET_GAME_ID_GIRO=612
HOLDET_GAME_ID_TDF=TBC
HOLDET_FANTASY_TEAM_ID=6796783
HOLDET_CARTRIDGE=giro-d-italia-2026
HOLDET_CARTRIDGE_TDF=tour-de-france-2026
